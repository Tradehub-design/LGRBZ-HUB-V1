    76	
    77	function newestFirst<T extends {
    78	  updatedAt: string;
    79	}>(
    80	  rows:
    81	    T[]
    82	): T[] {
    83	  return [
    84	    ...rows,
    85	  ].sort(
    86	    (
    87	      left,
    88	      right
    89	    ) =>
    90	      new Date(
    91	        right.updatedAt
    92	      ).getTime() -
    93	      new Date(
    94	        left.updatedAt
    95	      ).getTime()
    96	  );
    97	}
