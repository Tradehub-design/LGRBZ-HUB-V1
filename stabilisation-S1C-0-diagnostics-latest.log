    99	export function createMarketDataRefreshDiagnosticSummary(
   100	  coordinator:
   101	    MarketDataRefreshCoordinator =
   102	      getSharedMarketDataRefreshCoordinator()
   103	):
   104	  MarketDataRefreshDiagnosticSummary {
   105	  const jobs =
   106	    coordinatorJobs(coordinator);
   107	
   108	  return {
   109	    generatedAt:
   110	      new Date()
   111	        .toISOString(),
   112	
   113	    policy:
   114	      coordinatorPolicy(coordinator),
   115	
   116	    statistics:
   117	      coordinatorStatistics(coordinator)(),
   118	
   119	    activeJobs:
   120	      newestFirst(
   121	        jobs.filter(
   122	          (
   123	            job
   124	          ) =>
   125	            job.state ===
   126	            "RUNNING"
   127	        )
   128	      ),
   129	
   130	    queuedJobs:
   131	      newestFirst(
   132	        jobs.filter(
   133	          (
   134	            job
   135	          ) =>
   136	            job.state ===
   137	            "QUEUED"
   138	        )
   139	      ),
   140	
   141	    retryJobs:
   142	      newestFirst(
   143	        jobs.filter(
   144	          (
   145	            job
   146	          ) =>
   147	            job.state ===
   148	            "RETRY_WAIT"
   149	        )
   150	      ),
   151	
   152	    recentCompletedJobs:
   153	      newestFirst(
   154	        jobs.filter(
   155	          (
   156	            job
   157	          ) =>
   158	            job.state ===
   159	            "COMPLETED"
   160	        )
   161	      ).slice(
   162	        0,
   163	        50
   164	      ),
   165	
   166	    recentFailedJobs:
   167	      newestFirst(
   168	        jobs.filter(
   169	          (
   170	            job
   171	          ) =>
   172	            job.state ===
   173	            "FAILED"
   174	        )
   175	      ).slice(
   176	        0,
   177	        50
   178	      ),
   179	
   180	    providerHealth:
   181	      getSharedMultiProviderQuoteResolver()
   182	        .getHealthStore(),
   183	  };
