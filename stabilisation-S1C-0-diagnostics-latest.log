    22	
    23	function coordinatorJobs(
    24	  coordinator: unknown
    25	): unknown[] {
    26	  const surface =
    27	    coordinator as
    28	      RefreshCoordinatorDiagnosticSurface;
    29	
    30	  if (
    31	    typeof surface.getJobs ===
    32	    "function"
    33	  ) {
    34	    const jobs =
    35	      surface.getJobs();
    36	
    37	    return Array.isArray(jobs)
    38	      ? jobs
    39	      : [];
    40	  }
    41	
    42	  return Array.isArray(
    43	    surface.jobs
    44	  )
    45	    ? surface.jobs
    46	    : [];
    47	}
    48	
    49	function coordinatorPolicy(
    50	  coordinator: unknown
    51	): unknown {
