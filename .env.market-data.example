# LGRBZ-HUB unified market-data providers
#
# Configure at least one server-side API key.
# Do not expose these keys using NEXT_PUBLIC_ variables.

# Primary provider — supports batch quote requests.
TWELVE_DATA_API_KEY=

# Secondary provider.
FINNHUB_API_KEY=

# Final provider fallback.
ALPHA_VANTAGE_API_KEY=

# Dividend provider endpoints use the same server-side keys.
# Alpha Vantage DIVIDENDS:
# ALPHA_VANTAGE_API_KEY=
#
# Twelve Data /dividends:
# TWELVE_DATA_API_KEY=
